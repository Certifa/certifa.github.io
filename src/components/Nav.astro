---
const navLinks = [
  { href: '/',         label: 'Home' },
  { href: '/about',    label: 'About' },
  { href: '/projects', label: 'Projects' },
  { href: '/writeups', label: 'Writeups' },
  { href: '/skills',   label: 'Skills' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
---
<nav
  id="nav"
  class="fixed top-0 left-0 right-0 z-50 px-6
    bg-[rgba(8,8,15,0.8)] backdrop-blur-xl
    border-b border-[rgba(255,255,255,0.05)]
    transition-[padding] duration-300"
  style="padding-top: 1rem; padding-bottom: 1rem;"
>
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <a href="/" class="font-mono font-bold text-[#eaedf3] text-sm tracking-[0.2em] hover:text-[#7b9dd0] transition-colors select-none">
      CERTIFA
    </a>

    <!-- Desktop -->
    <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class={`
              relative font-sans text-sm px-4 py-2 rounded-lg transition-colors
              ${isActive(href)
                ? 'text-[#eaedf3] bg-[rgba(255,255,255,0.06)]'
                : 'text-[#4a4e60] hover:text-[#c8cad0] hover:bg-[rgba(255,255,255,0.03)]'}
            `}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger -->
    <button id="hamburger" aria-label="Toggle menu" aria-expanded="false"
      class="md:hidden flex flex-col justify-center gap-[5px] w-10 h-10">
      <span class="ham-line block w-5 h-px bg-[#c8cad0] transition-all origin-center"></span>
      <span class="ham-line block w-5 h-px bg-[#c8cad0] transition-all origin-center"></span>
      <span class="ham-line block w-3 h-px bg-[#c8cad0] transition-all origin-center self-end"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden overflow-hidden" style="max-height:0;transition:max-height 0.3s ease;">
    <ul class="flex flex-col gap-1 pt-3 pb-4 list-none m-0 p-0 max-w-6xl mx-auto">
      {navLinks.map(({ href, label }) => (
        <li>
          <a href={href} class={`mobile-nav-link block py-2.5 px-3 rounded-lg font-sans text-sm transition-colors
            ${isActive(href) ? 'text-[#eaedf3] bg-[rgba(255,255,255,0.06)]' : 'text-[#c8cad0] hover:bg-[rgba(255,255,255,0.04)]'}`}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const ham = document.getElementById('hamburger');
  const menu = document.getElementById('mobile-menu') as HTMLElement | null;
  ham?.addEventListener('click', () => {
    const open = menu?.style.maxHeight !== '' && menu?.style.maxHeight !== '0px';
    if (menu) menu.style.maxHeight = open ? '0px' : menu.scrollHeight + 'px';
    ham.setAttribute('aria-expanded', String(!open));
  });
  document.querySelectorAll('.mobile-nav-link').forEach(l => l.addEventListener('click', () => { if (menu) menu.style.maxHeight = '0px'; }));

  const nav = document.getElementById('nav');
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 50;
    nav?.style.setProperty('padding-top', scrolled ? '0.625rem' : '1rem');
    nav?.style.setProperty('padding-bottom', scrolled ? '0.625rem' : '1rem');
  }, { passive: true });
</script>
