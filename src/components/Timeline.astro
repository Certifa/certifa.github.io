---
const events = [
  { year: '2023', title: 'Started HackTheBox', desc: 'Began grinding HTB machines. Easy → Medium Windows/Linux. Got hooked.', accent: true },
  { year: '2024', title: 'Deep dive into Active Directory', desc: 'BloodHound, Kerberoasting, Pass-the-Hash, NTLM relay. Built first AD home lab.', accent: false },
  { year: '2025', title: '30+ Machines — including Insane', desc: 'Completed Fortress Jet.com (Insane). DarkZero Hard — MSSQL pivoting, CVE-2024-30088, Golden Ticket.', accent: true },
  { year: '2025', title: 'Python tooling & automation', desc: 'Started scripting recon utilities and automating HTB workflows.', accent: false },
  { year: '2026', title: 'CCNA & cloud fundamentals', desc: 'Expanding into networking and cloud. Still grinding HTB on the side.', accent: true },
];
---
<div class="space-y-7 relative">
  <div class="absolute left-[1.5rem] top-2 bottom-2 w-px bg-[rgba(255,255,255,0.05)] hidden sm:block"></div>
  {events.map((e, i) => (
    <div class="flex gap-6 reveal" style={`transition-delay:${i*70}ms`}>
      <div class="flex-shrink-0 w-12 flex justify-center pt-1">
        <div class={`w-3 h-3 rounded-full border-2 z-10 flex-shrink-0 ${e.accent ? 'bg-[#00e5ff] border-[#00e5ff]' : 'bg-[#08080f] border-[rgba(255,255,255,0.2)]'}`}></div>
      </div>
      <div class="pb-2">
        <div class="font-mono text-xs text-[#4a4e60] mb-1">{e.year}</div>
        <h3 class="font-sans font-semibold text-[#eaedf3] text-sm mb-1">{e.title}</h3>
        <p class="text-[#9da3b4] text-sm leading-relaxed">{e.desc}</p>
      </div>
    </div>
  ))}
</div>
